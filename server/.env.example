# ─── Server Configuration ────────────────────────────────────────────────────
PORT=5001

# ─── MongoDB Connection ──────────────────────────────────────────────────────
# Local MongoDB:  mongodb://localhost:27017/todo-db
# MongoDB Atlas:  mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/todo-db

# ─── Environment ─────────────────────────────────────────────────────────────
NODE_ENV=development
